---
import LogoAnimado from "../components/LogoAnimado.astro";
---

<section
    class="w-full mx-auto lg:w-[1100px] min-h-[95vh] flex flex-col justify-center px-4 text-center"
>
    <div>
        <LogoAnimado />
    </div>

    <div class="text-center">
        <h1
            class="font-raj text-[83px] tracking-[0.1em] bg-gradient-to-br from-white via-[#00c9a7] to-[#0a84ff] bg-clip-text text-transparent mt-4"
        >
            SAFENEX
        </h1>
        <p
            class="font-mono text-[10px] tracking-[0.4em] text-teal-500/80 uppercase"
        >
            Conexión Segura <span class="mx-2 opacity-50">•</span>
            Sistemas <span class="mx-2 opacity-50">•</span>
            Web <span class="mx-2 opacity-50">•</span>
            Tecnología
        </p>
    </div>

    <div class="flex flex-col items-center w-full mx-auto bg-[#020617] py-10">
        <div class="flex items-center justify-center">
            <div class="flex flex-col items-center gap-1 px-[28px] py-[14px]">
                <span
                    class="font-raj text-[22px] font-bold tracking-[3px] uppercase text-[#00c9a7]"
                >
                    Safe
                </span>
                <span
                    class="font-mono text-[9px] tracking-[2px] text-gray-500 uppercase"
                >
                    Seguro
                </span>
            </div>

            <div
                class="w-[1px] h-[40px] bg-[linear-gradient(to_bottom,transparent_0%,rgba(156,163,175,0.5)_50%,transparent_100%)]"
            >
            </div>

            <div class="flex flex-col items-center gap-1 px-[28px] py-[14px]">
                <span
                    class="font-raj text-[22px] font-bold tracking-[3px] uppercase text-[#0a84ff]"
                >
                    Nex
                </span>
                <span
                    class="font-mono text-[9px] tracking-[2px] text-gray-500 uppercase"
                >
                    Conexión
                </span>
            </div>
        </div>

        <div
            class="w-full h-[1px] mt-2 bg-[linear-gradient(90deg,transparent_0%,#00c9a7_30%,#0a84ff_70%,transparent_100%)] opacity-50"
        >
        </div>
    </div>

    <div class="flex flex-wrap justify-center gap-[10px] px-[24px] mb-[56px]">
        <div
            class="flex items-center gap-2 bg-[#0b1f3a] border border-[#0a2a44] rounded-full px-[18px] py-[9px] text-white text-[13px] font-semibold tracking-[1px] uppercase transition-all duration-300 ease-out hover:-translate-y-1 hover:border-[#00c9a7]/50 cursor-default"
        >
            <span
                class="w-[6px] h-[6px] rounded-full bg-[#00c9a7] shadow-[0_0_8px_#00c9a7]"
            ></span>
            Sistemas de Inventario
        </div>

        <div
            class="flex items-center gap-2 bg-[#0b1f3a] border border-[#0a2a44] rounded-full px-[18px] py-[9px] text-white text-[13px] font-semibold tracking-[1px] uppercase transition-all duration-300 ease-out hover:-translate-y-1 hover:border-[#00c9a7]/50 cursor-default"
        >
            <span
                class="w-[6px] h-[6px] rounded-full bg-[#00c9a7] shadow-[0_0_8px_#00c9a7]"
            ></span>
            Páginas Web
        </div>

        <!-- <div
            class="flex items-center gap-2 bg-[#0b1f3a] border border-[#0a2a44] rounded-full px-[18px] py-[9px] text-white text-[13px] font-semibold tracking-[1px] uppercase transition-all duration-300 ease-out hover:-translate-y-1 hover:border-[#00c9a7]/50 cursor-default"
        >
            <span
                class="w-[6px] h-[6px] rounded-full bg-[#00c9a7] shadow-[0_0_8px_#00c9a7]"
            ></span> 
            Equipos Informáticos
        </div> -->
    </div>
</section>
